#!/usr/bin/env bash
set -euo pipefail

# skills — Skills manager for shellm
# Manages a local directory of skills following the Agent Skills open
# standard (SKILL.md format). Pure bash, no external dependencies beyond
# bash 4+, jq, curl, and git.

# ---------------------------------------------------------------------------
# Config & defaults
# ---------------------------------------------------------------------------

SKILLS_VERSION="0.1.0"
SKILLS_DIR="${SKILLS_DIR:-./.skills}"
SHELLY_KERNEL_DIR="${SHELLY_KERNEL_DIR:-}"
SHELLY_KERNEL_TOKEN_BUDGET="${SHELLY_KERNEL_TOKEN_BUDGET:-8000}"
SKILLS_REMOTES="${SKILLS_REMOTES:-}"
VERBOSE=0

# Source per-repo rc file (flags > env vars > rc file)
if [[ -f ".skillsrc" ]]; then
    _pre_env=$(env | grep '^SKILLS_') || true
    source .skillsrc
    while IFS='=' read -r k v; do
        [[ -n "$k" ]] && export "$k=$v"
    done <<< "$_pre_env"
fi

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

die() { echo "skills: error: $*" >&2; exit 1; }

# Color output (respects NO_COLOR env var)
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    _bold='\033[1m'
    _dim='\033[90m'
    _blue='\033[1;34m'
    _cyan='\033[36m'
    _yellow='\033[33m'
    _reset='\033[0m'
else
    _bold='' _dim='' _blue='' _cyan='' _yellow='' _reset=''
fi

info() { printf "${_blue}▶${_reset} %b\n" "$*" >&2; }
dim() { printf "${_dim}  %s${_reset}\n" "$*" >&2; }
warn() { printf "${_yellow}⚠${_reset} %b\n" "$*" >&2; }

debug() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf "${_dim}[skills debug] %s${_reset}\n" "$*" >&2
    fi
}

# Extract a field from SKILL.md YAML frontmatter.
# Usage: frontmatter_field <file> <field>
# Handles unquoted, double-quoted, and single-quoted values.
frontmatter_field() {
    local file="$1" field="$2"
    sed -n '/^---$/,/^---$/p' "$file" \
        | grep "^${field}:" \
        | sed "s/^${field}:[[:space:]]*//" \
        | sed "s/^[\"']\(.*\)[\"']$/\1/"
}

# Resolve the skills directory (project-level or local).
skills_dir() {
    local project="${1:-0}"
    if [[ "$project" -eq 1 ]]; then
        echo ".skills"
    else
        echo "$SKILLS_DIR"
    fi
}

# Build deduplicated list of skill search directories.
# Checks: .skills (project), kernel dir (if set), SKILLS_DIR (identity/override)
_all_skill_dirs() {
    local d real _seen=""
    for d in ".skills" ${SHELLY_KERNEL_DIR:+"$SHELLY_KERNEL_DIR"} "$SKILLS_DIR"; do
        [[ -z "$d" ]] && continue
        real=$(cd "$d" 2>/dev/null && pwd) || real="$d"
        case "$_seen" in
            *"|$real|"*) continue ;;
        esac
        _seen="${_seen}|${real}|"
        echo "$d"
    done
}

# Label a skill directory as project, kernel, or local.
_skill_dir_label() {
    local dir="$1" dreal kreal
    dreal=$(cd "$dir" 2>/dev/null && pwd) || dreal="$dir"
    if [[ "$dir" == ".skills" ]]; then echo "project"
    elif [[ -n "$SHELLY_KERNEL_DIR" ]]; then
        kreal=$(cd "$SHELLY_KERNEL_DIR" 2>/dev/null && pwd) || kreal="$SHELLY_KERNEL_DIR"
        if [[ "$dreal" == "$kreal" ]]; then echo "kernel"; else echo "local"; fi
    else echo "local"
    fi
}

# Find a skill directory by name. Checks project-level first, then kernel, then local.
# Matches against the frontmatter `name` field, then the directory name.
# Prints the path to stdout, or returns 1 if not found.
find_skill() {
    local name="$1"
    local dir skill_dir skill_name

    while IFS= read -r dir; do
        [[ -d "$dir" ]] || continue

        # Match by directory name
        if [[ -d "$dir/$name" && -f "$dir/$name/SKILL.md" ]]; then
            echo "$dir/$name"
            return
        fi

        # Match by frontmatter name field
        for skill_dir in "$dir"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            skill_name=$(frontmatter_field "${skill_dir}SKILL.md" "name")
            if [[ "$skill_name" == "$name" ]]; then
                printf '%s' "${skill_dir%/}"
                return
            fi
        done
    done < <(_all_skill_dirs)
    return 1
}

# Estimate token count for a file (bytes / 4)
_token_estimate() {
    local file="$1"
    local bytes
    bytes=$(wc -c < "$file" | tr -d ' ')
    echo $(( bytes / 4 ))
}

# Show kernel token budget summary
_show_kernel_budget() {
    [[ -z "$SHELLY_KERNEL_DIR" || ! -d "$SHELLY_KERNEL_DIR" ]] && return 0

    local total=0
    local skill_dir name tokens
    for skill_dir in "$SHELLY_KERNEL_DIR"/*/; do
        [[ -f "${skill_dir}SKILL.md" ]] || continue
        tokens=$(_token_estimate "${skill_dir}SKILL.md")
        total=$(( total + tokens ))
    done

    printf "\n"
    printf "${_dim}Kernel total: ~%d / %d token budget${_reset}\n" "$total" "$SHELLY_KERNEL_TOKEN_BUDGET" >&2
    if [[ "$total" -gt "$SHELLY_KERNEL_TOKEN_BUDGET" ]]; then
        warn "Kernel exceeds token budget by ~$(( total - SHELLY_KERNEL_TOKEN_BUDGET )) tokens"
    fi
}

# ---------------------------------------------------------------------------
# Actions
# ---------------------------------------------------------------------------

action_list() {
    local found=0
    local dir label skill_dir name desc

    while IFS= read -r dir; do
        [[ -d "$dir" ]] || continue
        label=$(_skill_dir_label "$dir")

        for skill_dir in "$dir"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            found=1

            name=$(frontmatter_field "${skill_dir}SKILL.md" "name")
            desc=$(frontmatter_field "${skill_dir}SKILL.md" "description")
            [[ -z "$name" ]] && name=$(basename "$skill_dir")
            [[ ${#desc} -gt 60 ]] && desc="${desc:0:57}..."

            printf "  ${_bold}%-20s${_reset} %-60b ${_cyan}[%s]${_reset}\n" \
                "$name" "${_dim}${desc}" "$label"
        done
    done < <(_all_skill_dirs)

    if [[ "$found" -eq 0 ]]; then
        echo "No skills installed." >&2
        printf "  Run ${_bold}skills --init${_reset} to create one, or ${_bold}skills <query>${_reset} to search.\n" >&2
    fi
}

action_list_json() {
    local dir skill_dir name desc body
    local first=1

    printf '['
    while IFS= read -r dir; do
        [[ -d "$dir" ]] || continue
        for skill_dir in "$dir"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            name=$(frontmatter_field "${skill_dir}SKILL.md" "name")
            desc=$(frontmatter_field "${skill_dir}SKILL.md" "description")
            [[ -z "$name" ]] && name=$(basename "$skill_dir")
            body=$(sed -n '/^---$/,/^---$/d; p' "${skill_dir}SKILL.md")

            [[ "$first" -eq 1 ]] && first=0 || printf ','
            jq -n --arg n "$name" --arg d "$desc" --arg b "$body" \
                '{name: $n, description: $d, instructions: $b}'
        done
    done < <(_all_skill_dirs)
    printf ']\n'
}

action_search() {
    local query="$1"
    local found_local=0
    local dir skill_dir name desc

    # --- Local matches ---
    printf "${_bold}Installed${_reset}\n"

    while IFS= read -r dir; do
        [[ -d "$dir" ]] || continue
        for skill_dir in "$dir"/*/; do
            [[ -f "${skill_dir}SKILL.md" ]] || continue
            name=$(frontmatter_field "${skill_dir}SKILL.md" "name")
            desc=$(frontmatter_field "${skill_dir}SKILL.md" "description")
            [[ -z "$name" ]] && name=$(basename "$skill_dir")

            if printf '%s %s' "$name" "$desc" | grep -qi "$query"; then
                found_local=1
                printf "  ${_bold}%-20s${_reset} %s\n" "$name" "$desc"
            fi
        done
    done < <(_all_skill_dirs)

    [[ "$found_local" -eq 0 ]] && printf "  ${_dim}No local matches.${_reset}\n"
    echo ""

    # --- Remote matches (GitHub) ---
    printf "${_bold}Available${_reset}\n"

    local encoded_query
    encoded_query=$(printf '%s' "$query" | jq -sRr @uri)
    local api_url="https://api.github.com/search/repositories?q=${encoded_query}+filename:SKILL.md&per_page=10&sort=stars&order=desc"
    debug "GitHub API: $api_url"

    local response
    response=$(curl -sS --max-time 10 "$api_url" 2>/dev/null) || {
        printf "  ${_dim}GitHub search failed (network error).${_reset}\n"
        return 0
    }

    local api_msg
    api_msg=$(printf '%s' "$response" | jq -r '.message // empty' 2>/dev/null)
    if [[ -n "$api_msg" ]]; then
        printf "  ${_dim}GitHub API: %s${_reset}\n" "$api_msg"
        return 0
    fi

    local count
    count=$(printf '%s' "$response" | jq '.items | length' 2>/dev/null) || count=0

    if [[ "$count" -eq 0 ]]; then
        printf "  ${_dim}No remote matches.${_reset}\n"
        return 0
    fi

    printf '%s' "$response" | jq -r '.items[] | "\(.full_name)\t\(.description // "—")\t★ \(.stargazers_count)\t\(.html_url)"' \
        | while IFS=$'\t' read -r repo rdesc stars url; do
            [[ ${#rdesc} -gt 50 ]] && rdesc="${rdesc:0:47}..."
            printf "  ${_bold}%-30s${_reset} %-50s ${_dim}%s${_reset}\n" "$repo" "$rdesc" "$stars"
            dim "  $url"
        done
}

action_install() {
    local source="$1"
    local project="$2"
    local target_dir
    target_dir=$(skills_dir "$project")
    mkdir -p "$target_dir"

    local skill_src=""
    local cloned=0

    if [[ -d "$source" ]]; then
        # --- Local path ---
        [[ -f "$source/SKILL.md" ]] || die "No SKILL.md found in: $source"
        skill_src="$source"
    else
        # --- GitHub (shorthand or URL) ---
        local repo_url="$source"
        if [[ "$source" =~ ^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$ ]]; then
            repo_url="https://github.com/$source"
        fi
        [[ "$repo_url" =~ ^https?://github\.com/ ]] || die "Invalid source: $source (expected owner/repo, GitHub URL, or local path)"

        skill_src=$(mktemp -d)
        cloned=1

        info "Cloning $repo_url..."
        git clone --depth 1 --quiet "$repo_url" "$skill_src" 2>/dev/null \
            || { rm -rf "$skill_src"; die "Failed to clone: $repo_url"; }

        [[ -f "$skill_src/SKILL.md" ]] || { rm -rf "$skill_src"; die "No SKILL.md found in repository: $repo_url"; }
    fi

    # Read skill metadata
    local skill_name skill_desc
    skill_name=$(frontmatter_field "$skill_src/SKILL.md" "name")
    skill_desc=$(frontmatter_field "$skill_src/SKILL.md" "description")
    [[ -z "$skill_name" ]] && skill_name=$(basename "$source" .git)

    local install_dir="$target_dir/$skill_name"
    if [[ -d "$install_dir" ]]; then
        [[ "$cloned" -eq 1 ]] && rm -rf "$skill_src"
        die "Skill '$skill_name' already installed at: $install_dir"
    fi

    if [[ "$cloned" -eq 1 ]]; then
        mv "$skill_src" "$install_dir"
    else
        cp -R "$source" "$install_dir"
    fi

    rm -rf "$install_dir/.git"

    info "Installed: ${_bold}$skill_name${_reset}"
    [[ -n "$skill_desc" ]] && dim "$skill_desc"
}

action_remove() {
    local name="$1"
    local force="$2"

    local skill_dir
    skill_dir=$(find_skill "$name") || die "Skill not found: $name"

    if [[ "$force" -eq 0 ]]; then
        printf "Remove skill '%s' from %s? [y/N] " "$name" "$skill_dir" >&2
        local reply
        read -r reply
        [[ "$reply" =~ ^[Yy]$ ]] || { echo "Cancelled." >&2; return 0; }
    fi

    rm -rf "$skill_dir"
    info "Removed: $name"
}

action_show() {
    local name="$1"

    local skill_dir
    skill_dir=$(find_skill "$name") || die "Skill not found: $name"
    cat "$skill_dir/SKILL.md"
}

action_init() {
    local name="$1"
    local desc="$2"
    local project="${3:-0}"

    # Prompt interactively if not provided
    if [[ -z "$name" ]]; then
        if [[ -t 0 ]]; then
            printf "Skill name: " >&2
            read -r name
        fi
        [[ -z "$name" ]] && die "Name is required"
    fi

    if [[ -z "$desc" ]] && [[ -t 0 ]]; then
        printf "Description: " >&2
        read -r desc
    fi

    local target_dir
    target_dir=$(skills_dir "$project")
    local skill_dir="$target_dir/$name"
    [[ -d "$skill_dir" ]] && die "Directory already exists: $skill_dir"

    mkdir -p "$skill_dir"/{scripts,references,assets}

    cat > "$skill_dir/SKILL.md" << EOF
---
name: $name
description: $desc
---

# $name

## Instructions

<!-- Describe what this skill does and how an LLM should use it. -->
EOF

    info "Created skill scaffold: ${_bold}$skill_dir/${_reset}"
    dim "SKILL.md"
    dim "scripts/"
    dim "references/"
    dim "assets/"
}

action_promote() {
    local name="$1"

    [[ -z "$SHELLY_KERNEL_DIR" ]] && die "Not running inside shelly — kernel promotion requires an active identity"

    # Check if already in kernel
    if [[ -d "$SHELLY_KERNEL_DIR/$name" && -f "$SHELLY_KERNEL_DIR/$name/SKILL.md" ]]; then
        die "Skill '$name' is already in the kernel"
    fi

    # Also check by frontmatter name in kernel
    local kdir
    for kdir in "$SHELLY_KERNEL_DIR"/*/; do
        [[ -f "${kdir}SKILL.md" ]] || continue
        local kname
        kname=$(frontmatter_field "${kdir}SKILL.md" "name")
        if [[ "$kname" == "$name" ]]; then
            die "Skill '$name' is already in the kernel (as $(basename "$kdir"))"
        fi
    done

    # Find skill in SKILLS_DIR (identity's skills/)
    local skill_path=""
    if [[ -d "$SKILLS_DIR/$name" && -f "$SKILLS_DIR/$name/SKILL.md" ]]; then
        skill_path="$SKILLS_DIR/$name"
    else
        # Try frontmatter name match in SKILLS_DIR only
        local sdir
        for sdir in "$SKILLS_DIR"/*/; do
            [[ -f "${sdir}SKILL.md" ]] || continue
            local sname
            sname=$(frontmatter_field "${sdir}SKILL.md" "name")
            if [[ "$sname" == "$name" ]]; then
                skill_path="${sdir%/}"
                break
            fi
        done
    fi

    [[ -z "$skill_path" ]] && die "Skill '$name' not found in skills directory"

    # Move to kernel
    local dirname
    dirname=$(basename "$skill_path")
    mv "$skill_path" "$SHELLY_KERNEL_DIR/$dirname"

    info "Promoted ${_bold}$name${_reset} to kernel"
    _show_kernel_budget
}

action_demote() {
    local name="$1"
    local force="$2"

    [[ -z "$SHELLY_KERNEL_DIR" ]] && die "Not running inside shelly — kernel demotion requires an active identity"

    # Find skill in kernel
    local skill_path=""
    local actual_name=""
    if [[ -d "$SHELLY_KERNEL_DIR/$name" && -f "$SHELLY_KERNEL_DIR/$name/SKILL.md" ]]; then
        skill_path="$SHELLY_KERNEL_DIR/$name"
        actual_name="$name"
    else
        local kdir
        for kdir in "$SHELLY_KERNEL_DIR"/*/; do
            [[ -f "${kdir}SKILL.md" ]] || continue
            local kname
            kname=$(frontmatter_field "${kdir}SKILL.md" "name")
            if [[ "$kname" == "$name" ]]; then
                skill_path="${kdir%/}"
                actual_name="$name"
                break
            fi
        done
    fi

    [[ -z "$skill_path" ]] && die "Skill '$name' not found in kernel"

    # Refuse to demote mem unless --force
    if [[ "$actual_name" == "mem" && "$force" -eq 0 ]]; then
        die "Cannot demote 'mem' (core skill). Use --force to override."
    fi

    # Move to skills dir
    local dirname
    dirname=$(basename "$skill_path")
    mkdir -p "$SKILLS_DIR"
    mv "$skill_path" "$SKILLS_DIR/$dirname"

    info "Demoted ${_bold}$name${_reset} from kernel"
    _show_kernel_budget
}

action_kernel() {
    if [[ -z "$SHELLY_KERNEL_DIR" || ! -d "$SHELLY_KERNEL_DIR" ]]; then
        echo "No kernel directory (not running inside shelly?)." >&2
        return 0
    fi

    local found=0
    local total=0
    local skill_dir name tokens

    printf "${_bold}Kernel skills${_reset} ${_dim}(loaded on every turn)${_reset}\n" >&2

    for skill_dir in "$SHELLY_KERNEL_DIR"/*/; do
        [[ -f "${skill_dir}SKILL.md" ]] || continue
        found=1

        name=$(frontmatter_field "${skill_dir}SKILL.md" "name")
        [[ -z "$name" ]] && name=$(basename "$skill_dir")
        tokens=$(_token_estimate "${skill_dir}SKILL.md")
        total=$(( total + tokens ))

        printf "  ${_bold}%-20s${_reset} ${_dim}~%d tokens${_reset}\n" "$name" "$tokens" >&2
    done

    if [[ "$found" -eq 0 ]]; then
        printf "  ${_dim}(empty)${_reset}\n" >&2
    else
        printf "${_dim}Total: ~%d / %d token budget${_reset}\n" "$total" "$SHELLY_KERNEL_TOKEN_BUDGET" >&2
        if [[ "$total" -gt "$SHELLY_KERNEL_TOKEN_BUDGET" ]]; then
            warn "Kernel exceeds token budget by ~$(( total - SHELLY_KERNEL_TOKEN_BUDGET )) tokens"
        fi
    fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<'EOF'
skills — Skills manager for shellm

Usage:
  skills                                  List all installed skills
  skills list                             List all installed skills
  skills search <query>                   Search installed + remote skills
  skills install <owner/repo|url|path>    Install a skill
  skills remove <name>                    Remove an installed skill
  skills show <name>                      Print a skill's full SKILL.md
  skills init [name]                      Scaffold a new skill in current dir
  skills list-json                        List skills as JSON (for programmatic use)
  skills promote <name>                   Promote a skill to the kernel
  skills demote <name>                    Demote a kernel skill back to on-demand
  skills kernel                           Show kernel skills with token counts

Options:
  --dir DIR          Use DIR as the skills directory (default: ./.skills)
  --remotes REMOTES  Comma-separated list of remote skill sources
  --project          Target project-level .skills/ instead of local
  --force            Skip confirmation prompts
  --name NAME        Skill name (for init)
  --description DESC Skill description (for init)
  -v, --verbose      Verbose/debug mode
  -h, --help         Show help
  --version          Show version

Environment:
  SKILLS_DIR              Override skills directory (default: ./.skills)
  SKILLS_REMOTES          Remote skill sources (comma-separated)
  SHELLY_KERNEL_DIR       Kernel directory (set by shelly)
  SHELLY_KERNEL_TOKEN_BUDGET  Token budget for kernel (default: 8000)
  NO_COLOR                Disable color output
EOF
    exit 0
}

# ---------------------------------------------------------------------------
# Argument parsing & dispatch
# ---------------------------------------------------------------------------

main() {
    local action=""
    local action_arg=""
    local project=0
    local force=0
    local init_name=""
    local init_desc=""

    # Parse subcommand first (if present)
    if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
        case "$1" in
            list)      action="list";     shift ;;
            search)    action="search";   shift ;;
            install)   action="install";  shift ;;
            remove)    action="remove";   shift ;;
            show)      action="show";     shift ;;
            init)      action="init";     shift ;;
            promote)   action="promote";  shift ;;
            demote)    action="demote";   shift ;;
            kernel)    action="kernel";   shift ;;
            list-json) action="list-json"; shift ;;
        esac
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                ;;
            --version)
                echo "skills $SKILLS_VERSION"
                exit 0
                ;;
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            --dir)
                SKILLS_DIR="${2:?--dir requires a path}"
                shift 2
                ;;
            --project)
                project=1
                shift
                ;;
            --remotes)
                SKILLS_REMOTES="${2:?--remotes requires a value}"
                shift 2
                ;;
            --force)
                force=1
                shift
                ;;
            --name)
                init_name="${2:?--name requires a value}"
                shift 2
                ;;
            --description)
                init_desc="${2:?--description requires a value}"
                shift 2
                ;;
            # Legacy flag forms (still supported)
            --install)   action="install";  shift ;;
            --remove)    action="remove";   shift ;;
            --show)      action="show";     shift ;;
            --list-json) action="list-json"; shift ;;
            --init)      action="init";     shift ;;
            --promote)   action="promote";  shift ;;
            --demote)    action="demote";   shift ;;
            --kernel)    action="kernel";   shift ;;
            -*)
                die "Unknown option: $1 (try skills --help)"
                ;;
            *)
                break
                ;;
        esac
    done

    local remaining="$*"

    case "$action" in
        list)      action_list ;;
        list-json) action_list_json ;;
        kernel)    action_kernel ;;
        install)
            [[ -z "$remaining" ]] && die "install requires a source (owner/repo, URL, or path)"
            action_install "$remaining" "$project"
            ;;
        remove)
            [[ -z "$remaining" ]] && die "remove requires a skill name"
            action_remove "$remaining" "$force"
            ;;
        show)
            [[ -z "$remaining" ]] && die "show requires a skill name"
            action_show "$remaining"
            ;;
        promote)
            [[ -z "$remaining" ]] && die "promote requires a skill name"
            action_promote "$remaining"
            ;;
        demote)
            [[ -z "$remaining" ]] && die "demote requires a skill name"
            action_demote "$remaining" "$force"
            ;;
        search)
            [[ -z "$remaining" ]] && die "search requires a query"
            action_search "$remaining"
            ;;
        init)
            [[ -z "$init_name" && -n "$remaining" ]] && init_name="$remaining"
            action_init "$init_name" "$init_desc" "$project"
            ;;
        "")
            if [[ -n "$remaining" ]]; then
                action_search "$remaining"
            else
                action_list
            fi
            ;;
    esac
}

main "$@"
